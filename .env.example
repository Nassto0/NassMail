# --- Core ---
# Your NassMail domain. Users get addresses like alice@nassmail.com
NASS_DOMAIN=nassmail.com
# Same value, exposed to the browser (used on the register page UI)
NEXT_PUBLIC_NASS_DOMAIN=nassmail.com

# NextAuth (production: NEXTAUTH_URL must be your public URL, e.g. https://nassmail.com)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Database ---
# Local dev (SQLite) — prisma/schema.prisma must use provider "sqlite"
DATABASE_URL="file:./prisma/dev.db"
#
# Vercel production: SQLite is not durable on serverless. Use Postgres (Neon, Vercel Postgres,
# Supabase, or Render Postgres), set DATABASE_URL in Vercel → Environment Variables, change
# prisma/schema.prisma datasource provider to "postgresql", then from your machine run once:
#   npx prisma db push
# against the production DATABASE_URL (or use prisma migrate for teams).
# Render: optional; only if you want Postgres or a long-running SMTP relay there — not required
# for a standard Next.js + Vercel + Neon/Supabase setup.

# --- Mail provider (choose ONE by setting MAIL_PROVIDER) ---
# Options: resend | brevo | smtp | dev
MAIL_PROVIDER=dev

# Resend — https://resend.com  (3,000/month free, requires verified domain)
RESEND_API_KEY=

# Brevo — https://brevo.com  (300/day free, requires verified domain)
BREVO_API_KEY=

# Generic SMTP (Gmail app password, Zoho, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# --- Inbound webhook (to receive external mail) ---
# Shared secret your inbound provider (Mailgun Routes / CloudMailin / Resend Inbound)
# must send as ?token=... or X-Inbound-Token header.
INBOUND_WEBHOOK_SECRET=change-me
