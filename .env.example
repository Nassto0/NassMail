# --- Core ---
# Your NassMail domain. Users get addresses like alice@nassmail.com
NASS_DOMAIN=nassmail.com
# Same value, exposed to the browser (used on the register page UI)
NEXT_PUBLIC_NASS_DOMAIN=nassmail.com

# NextAuth (production: NEXTAUTH_URL must be your public URL, e.g. https://nassmail.com)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Database ---
# Local dev (SQLite) — prisma/schema.prisma must use provider "sqlite"
DATABASE_URL="file:./prisma/dev.db"
#
# Vercel production: SQLite is not durable on serverless. Use Postgres (Neon, Vercel Postgres,
# Supabase, or Render Postgres), set DATABASE_URL in Vercel → Environment Variables, change
# prisma/schema.prisma datasource provider to "postgresql", then from your machine run once:
#   npx prisma db push
# against the production DATABASE_URL (or use prisma migrate for teams).
# Render: optional; only if you want Postgres or a long-running SMTP relay there — not required
# for a standard Next.js + Vercel + Neon/Supabase setup.

# --- Mail provider (choose ONE by setting MAIL_PROVIDER) ---
# Options: resend | brevo | smtp | dev | gmail (see mailer.ts)
# Production (Vercel): set MAIL_PROVIDER=resend and RESEND_API_KEY in the Vercel project env (not only in .env).
# Local: use dev to skip sending, or resend + RESEND_API_KEY after verifying your domain in Resend.
MAIL_PROVIDER=dev

# Resend — https://resend.com (verify DNS for NASS_DOMAIN, then create an API key)
RESEND_API_KEY=

# Brevo — https://brevo.com  (300/day free, requires verified domain)
BREVO_API_KEY=

# Generic SMTP (Gmail app password, Zoho, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# --- Inbound IMAP cron (Vercel) ---
# Create a long random string, set it here AND in Vercel → CRON_SECRET (same value).
# Vercel Cron calls GET /api/inbound/poll with Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
# Optional: manual poll in browser — GET /api/inbound/poll?token=<same value as below>
# (token must match this variable; do not use "change-me" unless you set it here).
# Logged-in users can also run POST /api/inbound/refresh (Inbox → Refresh in the UI).
# Vercel Hobby: scheduled crons are limited to once per day — see vercel.json; use Refresh between runs.
IMAP_POLL_SECRET=

# Inbox the poller logs into (required for inbound). Must be set in .env locally AND in Vercel Production.
# Leave empty only if you never use IMAP pull (e.g. webhook-only inbound).
GMAIL_USER=
# App password (https://myaccount.google.com/apppasswords). Spaces optional — the app strips them.
GMAIL_APP_PASSWORD=

# Set to 1 for verbose server logs: [imap-poll] batch-start / SKIP no-recipient / IMPORT …
IMAP_DEBUG=

# Comma-separated IMAP paths to poll (default INBOX). Gmail Spam: INBOX,[Gmail]/Spam
IMAP_MAILBOXES=INBOX

# --- Inbound webhook (to receive external mail) ---
# Shared secret your inbound provider (Mailgun Routes / CloudMailin / Resend Inbound)
# must send as ?token=... or X-Inbound-Token header.
INBOUND_WEBHOOK_SECRET=change-me
